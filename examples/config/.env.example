# Environment Variables for SafeMySQLMcpServer
# Copy to .env and fill in your values
# NEVER commit this file with real secrets!

# JWT Secret (required, min 32 characters)
JWT_SECRET=your-secret-key-min-32-characters-long

# Database credentials for dev-cluster-1
DEV_DB_USER=your_db_user
DEV_DB_PASSWORD=your_db_password

# Optional: Database credentials for dev-cluster-2
# DEV2_DB_USER=your_db_user
# DEV2_DB_PASSWORD=your_db_password
