# SafeMySQLMcpServer environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env && make init

# ── Required ──
# JWT secret for API authentication (must be at least 32 characters)
# Run 'make init' to auto-generate, or set your own:
JWT_SECRET=

# ── Optional ──
# Config poll interval for Docker environments where fsnotify is unreliable
# Set to duration (e.g. 30s) or leave empty for fsnotify only
CONFIG_POLL_INTERVAL=30s

# App port mapping (host port)
APP_PORT=8080

# ── Dev only (used by docker-compose.dev.yml, not production) ──
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=testdb
MYSQL_USER=testuser
MYSQL_PASSWORD=testpassword
